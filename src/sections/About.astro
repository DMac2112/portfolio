---
import { Image } from 'astro:assets';
import { contentImage, type AboutItem, type HumanContent, type RevisedContent } from '../lib/content';

interface Props {
  abouts: AboutItem[];
  revised: RevisedContent['about'];
  human: HumanContent['about'];
}

const { abouts, revised, human } = Astro.props;
const variants = [
  { version: 'current', items: abouts },
  { version: 'revised', items: revised.items },
  { version: 'human', items: human.items },
];
const humanHeadingWords = human.heading.split(' ');
const humanHeadingAccent = humanHeadingWords.pop() || '';
const humanHeadingLead = humanHeadingWords.join(' ');
---

<section id="about" class="section bg-white" aria-labelledby="about-heading">
  <h2 id="about-heading" class="head-text">
    <span class="copy-heading" data-copy-version="current">
      What am I <span>About?</span><br />Well I am <span>a..</span>
    </span>
    <span class="copy-heading" data-copy-version="revised">
      Professional <span>Profile</span>
    </span>
    <span class="copy-heading" data-copy-version="human">
      {humanHeadingLead}{' '}<span>{humanHeadingAccent}</span>
    </span>
  </h2>

  {variants.map(({ version, items }) => (
    <div class="profiles" data-copy-version={version}>
      {items.map((about) => (
        <article class="profile reveal">
          <Image
            src={contentImage(about.image)}
            alt=""
            width={512}
            loading="lazy"
            decoding="async"
          />
          <h3 class="bold-text">{about.title}</h3>
          <p class="p-text">{about.description}</p>
        </article>
      ))}
    </div>
  ))}
</section>

<style>
  .head-text > .copy-heading {
    color: inherit;
  }

  .profiles {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .profile {
    width: 16rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 2rem;
    transition: transform 0.3s ease;
  }

  .profile:hover {
    transform: scale(1.05);
  }

  .profile img {
    width: 100%;
    height: 170px;
    border-radius: 15px;
    object-fit: cover;
    background-color: var(--primary-color);
  }

  .profile h3 {
    margin-top: 1.25rem;
  }

  .profile p {
    margin-top: 0.625rem;
  }
</style>
