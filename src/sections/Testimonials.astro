---
// Testimonial carousel. Every quote is server-rendered (crawlers see all of
// them); the page script only toggles which one is visible.
import { Image } from 'astro:assets';
import { contentImage, type HumanContent, type RevisedContent, type Testimonial } from '../lib/content';

interface Props {
  testimonials: Testimonial[];
  revised: RevisedContent['testimonials'];
  human: HumanContent['testimonials'];
}

const { testimonials, revised, human } = Astro.props;
const revisedHeadingWords = revised.heading.split(' ');
const revisedHeadingAccent = revisedHeadingWords.pop() || '';
const revisedHeadingLead = revisedHeadingWords.join(' ');
const humanHeadingWords = human.heading.split(' ');
const humanHeadingAccent = humanHeadingWords.pop() || '';
const humanHeadingLead = humanHeadingWords.join(' ');
---

{testimonials.length > 0 && (
  <section id="testimonial" class="section bg-primary" aria-labelledby="testimonial-heading">
    <h2 id="testimonial-heading" class="head-text">
      <span class="copy-heading" data-copy-version="current">What people <span>say</span></span>
      <span class="copy-heading" data-copy-version="revised">
        {revisedHeadingLead}{' '}<span>{revisedHeadingAccent}</span>
      </span>
      <span class="copy-heading" data-copy-version="human">
        {humanHeadingLead}{' '}<span>{humanHeadingAccent}</span>
      </span>
    </h2>

    <div class="t-stage" data-carousel>
      {testimonials.map((t, i) => (
        <figure class="t-card" data-slide={i} hidden={i !== 0}>
          <Image
            src={contentImage(t.image)}
            alt={`Portrait of ${t.name}`}
            width={200}
            loading="lazy"
            decoding="async"
          />
          <div class="t-content">
            <blockquote class="t-quote">{t.feedback}</blockquote>
            <figcaption>
              <span class="bold-text t-name">{t.name}</span>
              <span class="p-text t-company">{t.company}</span>
            </figcaption>
          </div>
        </figure>
      ))}

      {testimonials.length > 1 && (
        <div class="t-btns">
          <button type="button" data-carousel-prev aria-label="Previous testimonial">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20">
              <path d="m14 6-6 6 6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button type="button" data-carousel-next aria-label="Next testimonial">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20">
              <path d="m10 6 6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .head-text > .copy-heading {
    color: inherit;
  }

  .t-stage {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 2.5rem;
  }

  .t-card {
    width: min(60rem, 92%);
    min-height: 320px;
    background-color: var(--white-color);
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 2rem;
    border-radius: 15px;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.1);
  }

  .t-card[hidden] {
    display: none;
  }

  .t-card img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: contain;
    background-color: var(--primary-color);
    flex-shrink: 0;
  }

  .t-content {
    flex: 1;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .t-quote {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    max-width: 58ch;
    color: var(--black-color);
  }

  .t-name {
    display: block;
    color: var(--secondary-color);
    font-weight: 600;
  }

  .t-company {
    display: block;
    font-size: var(--text-sm);
    margin-top: 0.3125rem;
  }

  .t-btns {
    display: flex;
    flex-direction: row;
    margin-top: 1rem;
  }

  .t-btns button {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    background-color: var(--white-color);
    color: var(--secondary-color);
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 1rem;
    cursor: pointer;
    transition: all 0.3s ease-in-out;
  }

  .t-btns button:hover,
  .t-btns button:focus-visible {
    background-color: var(--secondary-color);
    color: var(--white-color);
  }

  @media screen and (max-width: 600px) {
    .t-card {
      flex-direction: column;
      gap: 1.5rem;
    }

    .t-content {
      padding: 0;
    }
  }
</style>
