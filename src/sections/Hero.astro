---
// Hero: dark section with the SEO-correct H1 (name + role — the old site's
// single H1 was "Hello!") and the DominikOS boot card as signature CTA.
import { Image } from 'astro:assets';
import OsLaunch from '../components/OsLaunch.astro';

import htmlIcon from '../assets/html.png';
import jsIcon from '../assets/javascript.png';
import cssIcon from '../assets/css.png';
import pythonIcon from '../assets/python.png';
import csharpIcon from '../assets/csharp.png';
import reactIcon from '../assets/react.png';

const leftCircles = [htmlIcon, jsIcon, cssIcon];
const rightCircles = [pythonIcon, csharpIcon, reactIcon];
---

<header id="home" class="section bg-dark hero">
  <div class="hero-circles hero-circles-left" aria-hidden="true">
    {leftCircles.map((icon) => (
      <div class="circle">
        <Image src={icon} alt="" width={120} loading="eager" />
      </div>
    ))}
  </div>

  <div class="hero-info">
    <p class="hero-greeting">Hello! My name is</p>
    <h1 class="hero-h1">
      <span class="hero-name">Dominik Machowiak</span>
      <span class="hero-role">Salesforce Marketing Cloud &amp; Front-End Developer</span>
    </h1>
    <p class="hero-sub">
      I build fast, polished web experiences — from React front-ends to large-scale
      marketing automation at Deloitte.
    </p>
    <div class="hero-ctas">
      <a class="hero-btn hero-btn-primary" href="#work">View my work</a>
      <a class="hero-btn" href="#contact">Contact me</a>
    </div>
    <OsLaunch />
  </div>

  <div class="hero-circles hero-circles-right" aria-hidden="true">
    {rightCircles.map((icon) => (
      <div class="circle">
        <Image src={icon} alt="" width={120} loading="eager" />
      </div>
    ))}
  </div>
</header>

<style>
  .hero {
    flex-direction: row;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-info {
    flex: 1;
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 0;
  }

  .hero-greeting {
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: var(--tracking-mono);
  }

  .hero-greeting::before {
    content: '> ';
    content: '> ' / ''; /* alt text: purely decorative for screen readers */
    color: var(--accent-color);
  }

  .hero-h1 {
    color: var(--white-color);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.5rem;
    text-wrap: balance;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: #9fd8e8;
    letter-spacing: var(--tracking-mono);
  }

  .hero-sub {
    margin-top: 1.1rem;
    max-width: 46ch;
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-base);
    line-height: var(--leading-body);
  }

  .hero-ctas {
    display: flex;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-btn {
    display: inline-block;
    font-size: var(--text-base);
    padding: 0.95rem 1.9rem;
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 10px;
    color: var(--white-color);
    text-decoration: none;
    font-weight: 500;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .hero-btn:hover,
  .hero-btn:focus-visible {
    background-color: var(--secondary-color);
    border-color: var(--secondary-color);
  }

  .hero-btn-primary {
    background-color: var(--secondary-color);
    border-color: var(--secondary-color);
  }

  .hero-btn-primary:hover,
  .hero-btn-primary:focus-visible {
    background-color: #2430af;
  }

  .hero-circles {
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    align-self: stretch;
    gap: 1.5rem;
  }

  .circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(4px);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .circle img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .hero-circles-left .circle:nth-child(1) {
    margin-left: 6rem;
  }

  .hero-circles-left .circle:nth-child(2) {
    width: 150px;
    height: 150px;
  }

  .hero-circles-left .circle:nth-child(3) {
    width: 70px;
    height: 70px;
    margin-left: auto;
  }

  .hero-circles-right .circle:nth-child(1) {
    margin-right: 6rem;
  }

  .hero-circles-right .circle:nth-child(2) {
    width: 150px;
    height: 150px;
    align-self: flex-end;
  }

  .hero-circles-right .circle:nth-child(3) {
    width: 70px;
    height: 70px;
  }

  @media screen and (max-width: 1024px) {
    .hero {
      flex-direction: column;
    }

    .hero-circles-left {
      display: none;
    }

    .hero-circles-right {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-self: auto;
      margin-top: 2rem;
    }

    .hero-circles-right .circle {
      margin: 0 !important;
      width: 90px;
      height: 90px;
    }
  }
</style>
