---
// The DominikOS boot card: a miniature desktop window that previews the real
// thing. Ported 1:1 from the CRA version (src/components/OsLaunch) — plain
// crawlable <a>, no framework, prefetch-on-intent via the small script below.
import CopyText from './CopyText.astro';
import type { HumanContent, RevisedContent } from '../lib/content';

interface Props {
  revised: RevisedContent['osLaunch'];
  human: HumanContent['osLaunch'];
}

const { revised, human } = Astro.props;
---

<div class="osl-wrap">
<a
  class="os-launch"
  href="/os/?boot=chooser"
  aria-label="Boot DominikOS — explore my portfolio as an interactive desktop, with a 2D game, pinball and my CV inside"
  data-os-launch
>
  <span class="osl-titlebar">
    <span class="osl-title">DominikOS</span>
    <span class="osl-buttons" aria-hidden="true">
      <span class="osl-btn osl-btn-min"></span>
      <span class="osl-btn osl-btn-max"></span>
      <span class="osl-btn osl-btn-close"></span>
    </span>
  </span>

  <span class="osl-body">
    <span class="osl-headline">
      <CopyText current="My portfolio is an operating system." revised={revised.headline} human={human.headline} />
    </span>
    <span class="osl-sub">
      <CopyText
        current="Boot a full desktop — open my projects and CV, play pinball, or walk my career as a 2D game."
        revised={revised.description}
        human={human.description}
      />
    </span>
    <span class="osl-boot">
      <span class="osl-power" aria-hidden="true">&#x23FB;</span>
      <CopyText current="Boot it up" revised={revised.buttonLabel} human={human.buttonLabel} />
    </span>
  </span>

  <span class="osl-taskbar" aria-hidden="true">
    <span class="osl-start">start</span>
    <span class="osl-apps">
      {['Desktop', '2D game', 'Pinball', 'CV'].map((label, index) => (
        <span>
          <CopyText
            current={label}
            revised={revised.taskbarLabels[index] || label}
            human={human.taskbarLabels[index] || label}
          />
        </span>
      ))}
    </span>
    <span class="osl-clock" data-osl-clock>--:--</span>
  </span>
</a>

  <!-- Straight to the CV: opens the PDF in place, no boot, no navigation. Sits outside the
       card's <a> because interactive content can't legally nest inside a link. -->
  <button class="osl-cv" type="button" data-cv-open aria-haspopup="dialog">
    <span class="osl-cv__icon" aria-hidden="true">📄</span>
    <span class="osl-cv__label">Just the CV</span>
    <span class="osl-cv__hint">PDF · opens right here</span>
  </button>
</div>

<dialog class="cv-dlg" data-cv-dlg aria-labelledby="cv-dlg-title">
  <div class="cv-dlg__win">
    <div class="cv-dlg__titlebar">
      <span class="cv-dlg__title" id="cv-dlg-title">Dominik Machowiak - CV</span>
      <button class="cv-dlg__x" type="button" data-cv-close aria-label="Close">&#x00D7;</button>
    </div>
    <div class="cv-dlg__bar">
      <a class="cv-dlg__btn" href="/os/assets/cv.pdf" download="Dominik-Machowiak-CV.pdf">&#x2913; Download</a>
      <a class="cv-dlg__btn" href="/os/assets/cv.pdf" target="_blank" rel="noopener">Open in new tab &#x2197;</a>
    </div>
    <!-- <object> renders the PDF inline on desktop; the fallback covers mobile browsers,
         which refuse inline PDFs and would otherwise show an empty frame. -->
    <object class="cv-dlg__frame" data="/os/assets/cv.pdf" type="application/pdf" title="Dominik Machowiak - CV">
      <div class="cv-dlg__fallback">
        <p>Your browser won't show PDFs inline.</p>
        <a class="cv-dlg__btn" href="/os/assets/cv.pdf" target="_blank" rel="noopener">Open the CV &#x2197;</a>
      </div>
    </object>
  </div>
</dialog>

<script>
  // Live clock + prefetch /os/ on first intent (hover/focus) so the click
  // feels instant without adding bytes to the initial load.
  const card = document.querySelector('[data-os-launch]');
  const clock = document.querySelector('[data-osl-clock]');

  if (clock) {
    const tick = () => {
      clock.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    };
    tick();
    setInterval(tick, 30000);
  }

  if (card) {
    let warmed = false;
    const warm = () => {
      if (warmed) return;
      warmed = true;
      const link = document.createElement('link');
      link.rel = 'prefetch';
      link.href = '/os/';
      document.head.appendChild(link);
    };
    card.addEventListener('pointerenter', warm, { once: true });
    card.addEventListener('focus', warm, { once: true });
  }

  // "Just the CV" — native <dialog> so Esc + backdrop dismissal come for free.
  const cvBtn = document.querySelector('[data-cv-open]');
  const cvDlg = document.querySelector('[data-cv-dlg]') as HTMLDialogElement | null;
  const cvX = document.querySelector('[data-cv-close]');

  if (cvBtn && cvDlg) {
    cvBtn.addEventListener('click', () => cvDlg.showModal());
    cvX?.addEventListener('click', () => cvDlg.close());
    // click the backdrop (the dialog element itself, outside the window) to close
    cvDlg.addEventListener('click', (e) => { if (e.target === cvDlg) cvDlg.close(); });
  }
</script>

<style>
  /* wrapper owns the centering so the CV button lines up under the card */
  .osl-wrap {
    width: 100%;
    max-width: 360px;
    margin: 2.25rem auto 0;
  }

  .os-launch {
    display: block;
    width: 100%;
    margin: 0;
    text-align: left;
    text-decoration: none;
    font-family: Tahoma, 'Segoe UI', Verdana, sans-serif;
    border-radius: 9px;
    overflow: hidden;
    background: #f2f0e8;
    border: 1px solid rgba(13, 36, 88, 0.65);
    box-shadow: 0 14px 34px -14px rgba(3, 12, 40, 0.65), 0 3px 10px rgba(3, 12, 40, 0.3);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .os-launch:hover,
  .os-launch:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 22px 44px -16px rgba(3, 12, 40, 0.75), 0 6px 16px rgba(3, 12, 40, 0.35);
  }

  .os-launch:focus-visible {
    outline: 3px solid #22d3ee;
    outline-offset: 3px;
  }

  .osl-titlebar {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 8px 7px 12px;
    background: linear-gradient(180deg, #4a7ff0 0%, #2a5ade 45%, #1d47bb 100%);
  }

  .osl-titlebar::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -40%;
    width: 35%;
    background: linear-gradient(105deg, transparent, rgba(255, 255, 255, 0.35), transparent);
    transform: translateX(0) skewX(-18deg);
    animation: osl-sheen 5.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes osl-sheen {
    0%,
    72% {
      transform: translateX(0) skewX(-18deg);
    }
    100% {
      transform: translateX(460%) skewX(-18deg);
    }
  }

  .osl-title {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .osl-buttons {
    display: flex;
    gap: 4px;
  }

  .osl-btn {
    position: relative;
    display: block;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.75);
    background: linear-gradient(180deg, #6f9bf5, #3a63d0);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.5);
  }

  .osl-btn::before {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 9px;
    line-height: 1;
    font-weight: 700;
  }

  .osl-btn-min::before {
    content: '\2013';
    align-items: flex-end;
    padding-bottom: 2px;
  }

  .osl-btn-max::before {
    content: '\25A1';
  }

  .osl-btn-close {
    background: linear-gradient(180deg, #f0836f, #d43d2a);
  }

  .osl-btn-close::before {
    content: '\00D7';
    font-size: 11px;
  }

  .osl-body {
    display: block;
    padding: 16px 16px 15px;
    background: linear-gradient(180deg, #fbfaf5, #f2f0e8);
  }

  .osl-headline {
    display: block;
    color: #101a33;
    font-size: 15.5px;
    font-weight: 700;
    line-height: 1.3;
  }

  .osl-sub {
    display: block;
    margin-top: 6px;
    color: #45506b;
    font-size: 12.5px;
    line-height: 1.5;
  }

  .osl-boot {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 13px;
    padding: 8px 16px;
    border-radius: 6px;
    background: linear-gradient(180deg, #43c258, #2f9e44 55%, #28863a);
    border: 1px solid #1f6e2f;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45), 0 2px 6px rgba(31, 110, 47, 0.4);
    transition: filter 0.15s ease;
  }

  .os-launch:hover .osl-boot,
  .os-launch:focus-visible .osl-boot {
    filter: brightness(1.08);
  }

  .osl-power {
    font-size: 14px;
    line-height: 1;
  }

  .osl-taskbar {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 28px;
    padding-right: 8px;
    background: linear-gradient(180deg, #3767e0, #2450c4 60%, #1c41a6);
    border-top: 1px solid rgba(255, 255, 255, 0.25);
  }

  .osl-start {
    align-self: stretch;
    display: flex;
    align-items: center;
    padding: 0 14px 0 10px;
    border-radius: 0 10px 10px 0;
    background: linear-gradient(180deg, #59b552, #3d9038);
    color: #fff;
    font-style: italic;
    font-weight: 700;
    font-size: 12px;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.35);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 2px 0 4px rgba(0, 0, 0, 0.25);
  }

  .osl-apps {
    flex: 1;
    min-width: 0;
    display: flex;
    gap: 8px;
    overflow: hidden;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.9);
    font-size: 10.5px;
  }

  .osl-apps span + span::before {
    content: '\00B7';
    margin-right: 8px;
    opacity: 0.6;
  }

  .osl-clock {
    color: #fff;
    font-size: 10.5px;
    padding: 2px 7px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 0 3px rgba(0, 0, 0, 0.3);
    font-variant-numeric: tabular-nums;
  }

  /* ---- "Just the CV" button ---- */
  .osl-cv {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    margin-top: 10px;
    padding: 9px 12px;
    cursor: pointer;
    font-family: Tahoma, 'Segoe UI', Verdana, sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #101a33;
    text-align: left;
    border: 1px solid rgba(13, 36, 88, 0.55);
    border-radius: 7px;
    background: linear-gradient(180deg, #fdfdfb, #e7e4d9);
    box-shadow: inset 0 1px 0 #fff, 0 3px 10px -4px rgba(3, 12, 40, 0.5);
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .osl-cv:hover,
  .osl-cv:focus-visible {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .osl-cv:focus-visible {
    outline: 3px solid #22d3ee;
    outline-offset: 3px;
  }

  .osl-cv:active { transform: translateY(1px); }
  .osl-cv__icon { font-size: 15px; line-height: 1; }
  .osl-cv__hint {
    margin-left: auto;
    font-size: 10.5px;
    font-weight: 400;
    color: #5a6480;
    white-space: nowrap;
  }

  /* ---- CV viewer: an XP window in a native <dialog> ---- */
  .cv-dlg {
    padding: 0;
    border: 0;
    background: transparent;
    max-width: 92vw;
    max-height: 92vh;
    width: 860px;
  }

  .cv-dlg::backdrop { background: rgba(3, 12, 40, 0.55); }

  .cv-dlg__win {
    display: flex;
    flex-direction: column;
    height: min(88vh, 900px);
    overflow: hidden;
    font-family: Tahoma, 'Segoe UI', Verdana, sans-serif;
    background: #f2f0e8;
    border: 1px solid rgba(13, 36, 88, 0.65);
    border-radius: 9px;
    box-shadow: 0 22px 44px -16px rgba(3, 12, 40, 0.75);
  }

  .cv-dlg__titlebar {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 8px 7px 12px;
    background: linear-gradient(180deg, #4a7ff0 0%, #2a5ade 45%, #1d47bb 100%);
  }

  .cv-dlg__title {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .cv-dlg__x {
    width: 18px;
    height: 18px;
    display: grid;
    place-items: center;
    cursor: pointer;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 4px;
    background: linear-gradient(180deg, #f0836f, #d43d2a);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.4);
  }

  .cv-dlg__x:hover { filter: brightness(1.1); }

  .cv-dlg__bar {
    flex: none;
    display: flex;
    gap: 6px;
    padding: 6px 8px;
    border-bottom: 1px solid #cdc9bb;
    background: linear-gradient(180deg, #fbfaf5, #eeebe1);
  }

  .cv-dlg__btn {
    padding: 5px 11px;
    font-size: 12px;
    font-weight: 700;
    color: #101a33;
    text-decoration: none;
    border: 1px solid #9a9683;
    border-radius: 4px;
    background: linear-gradient(180deg, #fdfdfb, #e4e1d6);
    box-shadow: inset 0 1px 0 #fff;
  }

  .cv-dlg__btn:hover { filter: brightness(1.05); }

  .cv-dlg__frame {
    flex: 1;
    width: 100%;
    min-height: 0;
    border: 0;
    background: #555;
  }

  .cv-dlg__fallback {
    display: grid;
    place-items: center;
    gap: 12px;
    height: 100%;
    padding: 24px;
    color: #f4f6fb;
    font-size: 13px;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .osl-cv {
      transition: none;
    }

    .osl-cv:hover,
    .osl-cv:focus-visible {
      transform: none;
    }

    .os-launch {
      transition: none;
    }

    .os-launch:hover,
    .os-launch:focus-visible {
      transform: none;
    }

    .osl-titlebar::after {
      animation: none;
      display: none;
    }
  }
</style>
