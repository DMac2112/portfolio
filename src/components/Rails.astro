---
// Fixed page furniture rendered ONCE (the old AppWrap HOC repeated these
// per-section, six copies in the DOM). Left: social. Right: section dots.
const sections = ['home', 'about', 'work', 'skills', 'testimonial', 'dominikos', 'contact'];
---

<div class="rail-social">
  <a href="mailto:dominikmachowiak101@gmail.com" aria-label="Email Dominik">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="15" height="15">
      <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2" />
      <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </a>
  <a
    href="https://www.linkedin.com/in/dominikmachowiak/"
    target="_blank"
    rel="noreferrer noopener"
    aria-label="Dominik on LinkedIn"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="15" height="15">
      <path d="M6.5 8.5v11h-3v-11h3Zm.2-3.4a1.7 1.7 0 1 1-3.4 0 1.7 1.7 0 0 1 3.4 0ZM20.5 13c0-3.1-1.7-4.7-4-4.7-1.8 0-2.6 1-3.1 1.7V8.5h-3c0 .8 0 11 0 11h3v-6.1c0-.3 0-.7.1-.9.3-.7.8-1.4 1.8-1.4 1.2 0 1.7 1 1.7 2.4v6h3v-6.5Z" />
    </svg>
  </a>
</div>

<nav class="rail-dots" aria-label="Section navigation">
  {sections.map((item) => (
    <a href={`#${item}`} data-dot={item}>
      <span class="sr-only">{`Jump to ${item}`}</span>
    </a>
  ))}
</nav>
