---
// Fixed top navbar. Desktop: inline links. Mobile: accessible slide-in panel
// driven by ~15 lines of vanilla JS in site script (no framework).
import type { HumanContent, RevisedContent } from '../lib/content';

interface Props {
  revised: RevisedContent['navigation'];
  human: HumanContent['navigation'];
}

const { revised, human } = Astro.props;
const links = ['home', 'about', 'work', 'skills', 'dominikos', 'contact'];
const revisedLabel = (id: string) => revised.links.find((link) => link.id === id)?.label || id;
const humanLabel = (id: string) => human.links.find((link) => link.id === id)?.label || id;
---

<nav class="navbar" aria-label="Main">
  <ul class="navbar-links">
    {links.map((item) => (
      <li>
        <a href={`#${item}`}>
          <span data-copy-version="current">{item === 'dominikos' ? 'DominikOS' : item}</span>
          <span data-copy-version="revised">{revisedLabel(item)}</span>
          <span data-copy-version="human">{humanLabel(item)}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="navbar-controls" role="group" aria-label="Portfolio display options">
    <button
      class="nav-option-toggle copy-toggle"
      type="button"
      aria-label="Copy version: Original. Activate formal version."
      data-copy-active="current"
      data-copy-toggle
    >
      <span class="toggle-prefix">Voice: </span><span data-copy-toggle-label>Original</span>
      <span class="sr-only" data-copy-toggle-action>. Activate formal version.</span>
    </button>

    <button
      class="nav-option-toggle style-toggle"
      type="button"
      aria-label="Style: Classic. Activate editorial style."
      data-style-active="classic"
      data-style-toggle
    >
      <span class="toggle-prefix">Style: </span><span data-style-toggle-label>Classic</span>
      <span class="sr-only" data-style-toggle-action>. Activate editorial style.</span>
    </button>

    <button
      class="nav-option-toggle palette-toggle"
      type="button"
      aria-label="Colour palette: Cloud, light mode. Activate Paper, light mode."
      data-palette-active="cloud"
      data-palette-toggle
    >
      <span class="palette-swatch" aria-hidden="true"></span>
      <span class="toggle-prefix">Colour: </span><span data-palette-toggle-label>Cloud</span>
      <span class="toggle-detail" data-palette-toggle-mode> · Light</span>
      <span class="sr-only" data-palette-toggle-action>. Activate Paper, light mode.</span>
    </button>
  </div>

  <button
    class="navbar-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-nav-toggle
  >
    <span class="sr-only">Open menu</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 7h16M4 12h16M4 17h10" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </button>

  <div class="navbar-panel" id="mobile-menu" hidden data-nav-panel>
    <button class="navbar-close" type="button" data-nav-close>
      <span class="sr-only">Close menu</span>
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
    <ul>
      {links.map((item) => (
        <li>
          <a href={`#${item}`} data-nav-link>
            <span data-copy-version="current">{item === 'dominikos' ? 'DominikOS' : item}</span>
            <span data-copy-version="revised">{revisedLabel(item)}</span>
            <span data-copy-version="human">{humanLabel(item)}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem var(--space-gutter);
    background: var(--nav-bg, rgba(255, 255, 255, 0.95));
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border-color, rgba(255, 255, 255, 0.25));
    position: fixed;
    top: 0;
    left: 0;
    z-index: 20;
    box-shadow: 0 2px 8px var(--shadow-color, rgba(0, 0, 0, 0.05));
  }

  .navbar-links {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    list-style: none;
    gap: 0.5rem;
  }

  .navbar-links a {
    display: inline-block;
    color: var(--text-muted-color, var(--gray-color));
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border-radius: 5px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-weight: 500;
    transition: all 0.3s ease-in-out;
  }

  .navbar-links a:hover,
  .navbar-links a:focus-visible {
    color: var(--on-accent, var(--white-color));
    background-color: var(--accent-color, var(--secondary-color));
  }

  .navbar-controls {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-option-toggle {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    border: 1px solid var(--border-color, var(--secondary-color));
    border-radius: 999px;
    padding: 0.45rem 0.7rem;
    background: var(--surface-color, var(--white-color));
    color: var(--text-color, var(--secondary-color));
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    line-height: 1;
    letter-spacing: var(--tracking-mono);
    white-space: nowrap;
    cursor: pointer;
    transition: color 0.2s ease-in-out, background-color 0.2s ease-in-out, border-color 0.2s ease-in-out;
  }

  .nav-option-toggle:hover,
  .nav-option-toggle:focus-visible {
    border-color: var(--accent-color, var(--secondary-color));
    background-color: var(--accent-color, var(--secondary-color));
    color: var(--on-accent, var(--white-color));
  }

  .palette-swatch {
    width: 0.55rem;
    height: 0.55rem;
    margin-right: 0.35rem;
    border: 1px solid currentColor;
    border-radius: 50%;
    background: var(--accent-color, var(--secondary-color));
  }

  @media screen and (max-width: 1180px) {
    .toggle-prefix {
      display: none;
    }
  }

  @media screen and (max-width: 900px) {
    .navbar-links {
      display: none;
    }

    .navbar-controls {
      margin-left: auto;
    }
  }

  @media screen and (max-width: 560px) {
    .navbar {
      padding-inline: 0.65rem;
    }

    .navbar-controls {
      gap: 0.25rem;
    }

    .nav-option-toggle {
      min-height: 32px;
      padding-inline: 0.5rem;
      font-size: 0.63rem;
    }

    .toggle-detail {
      display: none;
    }

    .palette-swatch {
      margin-right: 0.25rem;
    }
  }

  @media screen and (max-width: 390px) {
    .palette-swatch {
      display: none;
    }
  }

  .navbar-toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    display: none;
    justify-content: center;
    align-items: center;
    background: var(--accent-color, var(--secondary-color));
    color: var(--on-accent, var(--white-color));
    cursor: pointer;
    box-shadow: 0 4px 12px var(--shadow-color, rgba(49, 59, 172, 0.25));
  }

  @media screen and (max-width: 900px) {
    .navbar-toggle {
      display: flex;
      margin-left: 0.5rem;
    }
  }

  .navbar-panel {
    position: fixed;
    top: 0;
    bottom: 0;
    right: 0;
    z-index: 30;
    padding: 1.5rem;
    width: min(75%, 400px);
    height: 100vh;
    display: flex;
    justify-content: flex-start;
    align-items: flex-end;
    flex-direction: column;
    background-color: var(--surface-color, var(--white-color));
    box-shadow: -4px 0 16px var(--shadow-color, rgba(0, 0, 0, 0.1));
  }

  .navbar-panel[hidden] {
    display: none;
  }

  .navbar-close {
    background: none;
    border: none;
    color: var(--secondary-color);
    cursor: pointer;
    margin: 0.5rem 0.5rem 1rem;
  }

  .navbar-panel ul {
    list-style: none;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
    padding: 1rem;
  }

  .navbar-panel a {
    color: var(--text-muted-color, var(--gray-color));
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-weight: 500;
    transition: color 0.3s ease-in-out;
  }

  .navbar-panel a:hover,
  .navbar-panel a:focus-visible {
    color: var(--secondary-color);
  }
</style>
