{
  "name": "dominikos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DominikOS — Dominik Machowiak's portfolio as a retro desktop OS. Deploys to /os/.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/legal-gate.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "gate": "node scripts/legal-gate.mjs",
    "ci": "npm run typecheck && npm test && vite build && npm run gate",
    "deploy:local": "node scripts/deploy-local.mjs"
  },
  "dependencies": {
    "@xstate/react": "^4.1.3",
    "dompurify": "^3.1.7",
    "gray-matter": "^4.0.3",
    "marked": "^9.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xp.css": "^0.2.6",
    "xstate": "^5.19.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@fontsource/dejavu-sans": "^5.0.0",
    "@types/node": "^18.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "kaplay": "3001.0.19",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "vite": "^4.5.5",
    "vitest": "^0.34.6"
  }
}
