{
  "rewrites": [{ "source": "/os/(.*)", "destination": "/os/index.html" }],
  "headers": [
    {
      "source": "/os/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/os/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        {
          "key": "Content-Security-Policy",
          "value": "frame-src 'self' https://dominikmachowiak.com; frame-ancestors 'self'"
        }
      ]
    }
  ]
}
